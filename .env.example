# ===========================================
# REUNI-O - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local no ambiente local
# ou para .env.production.local no servidor Linux.

# -------------------------------------------
# MySQL (Prisma)
# -------------------------------------------
DATABASE_URL="mysql://usuario:senha@host:3306/reunio"

# -------------------------------------------
# NextAuth
# -------------------------------------------
# URL publica da aplicacao (sem barra no final)
NEXTAUTH_URL=http://localhost:3000

# URL interna opcional para o servidor acessar a propria app.
# Em producao com Nginx, use http://127.0.0.1:3000
NEXTAUTH_URL_INTERNAL=http://127.0.0.1:3000

# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=sua_chave_secreta_aqui

# -------------------------------------------
# Aplicacao
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# -------------------------------------------
# Resend (Email)
# -------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dominio permitido para emails de reserva.
# Deixe vazio para permitir qualquer dominio.
ALLOWED_EMAIL_DOMAIN=bexp.com.br

# -------------------------------------------
# Cron Jobs (opcional)
# -------------------------------------------
CRON_SECRET=seu_segredo_cron_aqui
